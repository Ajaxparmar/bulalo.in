// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SHOP_OWNER
  ADMIN
}

enum BusinessStatus {
  PENDING_PAYMENT
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
  REJECTED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum PaymentPurpose {
  BUSINESS_REGISTRATION
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  phone        String   @unique
  passwordHash String
  name         String?
  email        String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  businesses Business[]
  payments   Payment[]
  sessions   Session[]

  @@index([role])
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tokenHash String   @unique
  userId    String   @db.ObjectId
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Business {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  ownerId     String         @db.ObjectId
  name        String
  slug        String         @unique
  description String?
  logoUrl     String?
  coverUrl    String?
  phone       String
  whatsapp    String?
  email       String?
  website     String?
  address     String
  city        String
  state       String
  pincode     String
  latitude    Float?
  longitude   Float?
  status      BusinessStatus @default(PENDING_PAYMENT)
  isTopListing Boolean?       @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  owner         User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  payments      Payment[]
  categories    BusinessCategory[]
  subscriptions BusinessSubscription[]
  ratings       BusinessRating[]
  visits        BusinessVisit[]

  @@index([ownerId])
  @@index([status])
  @@index([isTopListing, status])
  @@index([city, status])
}

model BusinessVisit {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId String   @db.ObjectId
  ipAddress  String?
  userAgent  String?
  referrer   String?
  path       String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([createdAt])
}

model BusinessRating {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId    String   @db.ObjectId
  rating        Int
  reviewerToken String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, reviewerToken])
  @@index([businessId, createdAt])
}

model MainCategory {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  imageUrl    String
  imageAlt    String?
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businesses BusinessCategory[]
  homepageCards HomepageCard[]
  homepageTopCards HomepageTopCard[]
  homepageBanners HomepageBanner[]
  footerPopularEntries FooterPopularCategory[]

  @@index([isActive, sortOrder])
}

model BusinessCategory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId     String   @db.ObjectId
  mainCategoryId String   @db.ObjectId
  createdAt      DateTime @default(now())

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Cascade)

  @@unique([businessId, mainCategoryId])
  @@index([mainCategoryId])
}

model SubscriptionPlan {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  durationMonths Int
  pricePaise     Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions BusinessSubscription[]
  payments      Payment[]

  @@index([isActive, durationMonths])
}

model BusinessSubscription {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  businessId String   @db.ObjectId
  planId     String   @db.ObjectId
  startsAt   DateTime
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  paymentId  String?  @db.ObjectId

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  payment  Payment?         @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([businessId, expiresAt])
  @@index([expiresAt])
  @@index([paymentId])
  @@index([planId])
}

model Payment {
  id                    String         @id @default(auto()) @map("_id") @db.ObjectId
  userId                String         @db.ObjectId
  businessId            String?        @db.ObjectId
  planId                String?        @db.ObjectId
  purpose               PaymentPurpose @default(BUSINESS_REGISTRATION)
  status                PaymentStatus  @default(CREATED)
  amountPaise           Int            @default(30000)
  currency              String         @default("INR")
  razorpayOrderId       String         @unique
  razorpayPaymentId     String?
  razorpaySignature     String?
  razorpayReceipt       String?
  razorpayMethod        String?
  razorpayCapturedAt    DateTime?
  razorpayFailureCode   String?
  razorpayFailureReason String?
  rawResponse           Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  business      Business?              @relation(fields: [businessId], references: [id], onDelete: SetNull)
  plan          SubscriptionPlan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscriptions BusinessSubscription[]

  @@index([userId])
  @@index([businessId])
  @@index([planId])
  @@index([razorpayPaymentId])
  @@index([status])
}

model SiteSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  label     String?
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageCard {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  imageUrl       String
  imageAlt       String?
  linkUrl        String
  mainCategoryId String?  @db.ObjectId
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mainCategory MainCategory? @relation(fields: [mainCategoryId], references: [id], onDelete: SetNull)

  @@index([isActive, sortOrder])
  @@index([mainCategoryId])
}

model HomepageTopCard {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  imageUrl       String
  imageAlt       String?
  mainCategoryId String   @db.ObjectId
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
  @@index([mainCategoryId])
}

model HomepageBanner {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  eyebrow        String?
  title          String
  detail         String?
  imageUrl       String
  imageAlt       String?
  mainCategoryId String   @db.ObjectId
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
  @@index([mainCategoryId])
}

model FooterPopularCategory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  mainCategoryId String   @unique @db.ObjectId
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mainCategory MainCategory @relation(fields: [mainCategoryId], references: [id], onDelete: Cascade)

  @@index([isActive, sortOrder])
}
