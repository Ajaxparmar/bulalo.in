DATABASE_URL="mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority"

# Reserved application secret. Generate once with: openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL used when deploying the application.
AUTH_URL="http://localhost:3000"

# Optional override. When omitted, HTTPS is detected from AUTH_URL.
# AUTH_COOKIE_SECURE="false"

RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_key_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"
