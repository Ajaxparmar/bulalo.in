DATABASE_URL="mongodb+srv://USER:PASSWORD@HOST/DATABASE?retryWrites=true&w=majority"

# Required in production. Generate once with: openssl rand -base64 48
# Use exactly the same value during build and runtime, on every server instance.
AUTH_SECRET="replace-with-a-long-random-secret"

# Public URL used when deploying the application.
AUTH_URL="http://localhost:3000"

# Use false for local `npm start` over HTTP. Use true only when the public URL is HTTPS.
AUTH_COOKIE_SECURE="false"
